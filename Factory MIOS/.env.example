# ---- Copy to .env and edit. NEVER commit .env ----
# Database (TimescaleDB / PostgreSQL)
POSTGRES_USER=mios
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=mios
DB_PORT=5433
DATABASE_URL=postgresql+psycopg://mios:change-me-in-prod@db:5432/mios

# Redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ---- MQTT (OPTIONAL — bring your own broker) ----
# Nothing is hardcoded. The MQTT ingestor stays idle unless you configure these
# AND start the 'mqtt' compose profile:  docker compose --profile mqtt up
MQTT_ENABLED=false
MQTT_HOST=
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TLS=false
MQTT_TOPIC_PREFIX=mios/telemetry
# Ports for the optional bundled Mosquitto broker (only used with --profile mqtt)
MQTT_WS_PORT=9001

# Security — generate with: openssl rand -hex 32
SECRET_KEY=replace-with-a-64-char-random-hex-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
# Comma-separated allowed origins for CORS
CORS_ORIGINS=http://localhost:3000

# Ports
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# First platform admin (created on seed)
ADMIN_EMAIL=admin@factory-mios.local
ADMIN_PASSWORD=ChangeMe!2026

# Demo telemetry simulator interval (seconds), used with --profile demo
SIM_INTERVAL=5

# Optional: AI assistant (chatbot). Leave blank to use built-in rule-based fallback.
ANTHROPIC_API_KEY=
