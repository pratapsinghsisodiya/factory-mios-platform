# ══════════════════════════════════════════════════════════
#  FACTORY-MIOS — Environment Configuration
#  Copy this file to .env and fill in your real values.
#  Do not commit .env to Git.
# ══════════════════════════════════════════════════════════

# ── SERVER ──────────────────────────────────────────────
PORT=3000
HTTP_PORT=8080
TZ=Asia/Kolkata

# ── DATABASE (TimescaleDB / PostgreSQL) ─────────────────
# docker-compose uses POSTGRES_* + PG* values below.
# If you deploy to a managed DB, set DATABASE_URL/CNC_DATABASE_URL instead.
POSTGRES_DB=cnc_db
POSTGRES_USER=cnc_user
POSTGRES_PASSWORD=replace_with_strong_database_password
POSTGRES_PORT=5432
ADMINER_PORT=8081
NODE_RED_PORT=1880

PGHOST=db
PGPORT=5432
PGDATABASE=cnc_db
PGUSER=cnc_user
PGPASSWORD=replace_with_strong_database_password

# DATABASE_URL=postgresql://cnc_user:replace_with_strong_database_password@db:5432/cnc_db
# CNC_DATABASE_URL=postgresql://cnc_user:replace_with_strong_database_password@db:5432/cnc_db

# ── FACTO-BOT ──────────────────────────────────────
# Get free key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Claude / Anthropic (paid)
# ANTHROPIC_API_KEY=sk-ant-...

# ── NODE-RED ─────────────────────────────────────────────
# For Docker on Linux, host.docker.internal is mapped to the host by docker-compose.
NODE_RED_URL=http://host.docker.internal:1880/api/live
DATA_IMPORT_DIR=/app/imports
DATA_SOURCE_PREVIEW_ROWS=100
DATA_SOURCE_CACHE_TTL_MS=30000
DATA_SOURCE_SQL_TIMEOUT_MS=10000
DATA_SOURCE_MQTT_TIMEOUT_MS=10000

# ── SECURITY ─────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
DATA_CONNECTOR_SECRET=replace_with_connector_encryption_secret
JWT_SECRET=replace_with_very_long_random_jwt_secret
JWT_EXPIRE=24h
JSON_BODY_LIMIT=1mb
RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_MAX=20
AI_RATE_LIMIT_MAX=60
ALLOW_QUERY_TOKEN_AUTH=false
ENABLE_DEFAULT_USERS=false

# ── ThingsBoard ──────────────────────────────────────────
TB_TOKEN=
TB_MACHINE_ID=MACHINE001

# ── MQTT (for direct subscription if needed) ─────────────
MQTT_BROKER=mqtt://your-mqtt-host:1883
MQTT_TOPIC=factory-machine001
