{
  "_comment": "Factory-MIOS — Alert rules. Managed by /api/alerts endpoints.",
  "rules": [
    {
      "id": "rule_oee_critical",
      "name": "OEE Critical Drop",
      "active": true,
      "signal": "PLANT_OEE",
      "condition": "lt",
      "threshold": 65,
      "severity": "critical",
      "message": "🔴 CRITICAL: Plant OEE dropped below 65% — immediate intervention required",
      "delivery": ["email"],
      "emails": [],
      "phones": [],
      "cooldown": 30,
      "created_at": "2026-04-28T00:00:00.000Z",
      "last_triggered": null
    },
    {
      "id": "rule_oee_warn",
      "name": "OEE Warning Threshold",
